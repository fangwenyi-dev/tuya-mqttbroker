/**
 * @file tuya_config_secrets.h
 * @brief 涂鸦授权信息（UUID / AuthKey）
 *
 * 此文件包含设备授权码，不应提交到版本仓库。
 * 请将本文件复制为 tuya_config_secrets.h 并填入真实授权信息。
 *
 * 获取方式：
 * 1. 在涂鸦 IoT 平台创建产品，获取 Product ID (PID)
 * 2. 在 https://platform.tuya.com/purchase/index?type=6 申请 open-sdk 授权码
 * 3. 获取 UUID 和 AuthKey，填入下方宏定义
 *
 * @copyright Copyright (c) 2024-2025. All Rights Reserved.
 */

#ifndef __TUYA_CONFIG_SECRETS_H__
#define __TUYA_CONFIG_SECRETS_H__

#include "tuya_cloud_types.h"

#ifdef __cplusplus
extern "C" {
#endif

/**
 * @brief 产品信息配置
 *
 * TUYA_PRODUCT_ID: PID, 在涂鸦 IoT 平台创建产品后获取
 * TUYA_OPENSDK_UUID: UUID, 在涂鸦平台申请 open-sdk 授权码获取
 * TUYA_OPENSDK_AUTHKEY: AUTHKEY, 同上
 */
// clang-format off
#define TUYA_PRODUCT_ID      "your_product_id_here"                    // 请替换为你的产品 ID
#define TUYA_OPENSDK_UUID      "uuidxxxxxxxxxxxxxxxx"                    // 请替换为正确的 UUID
#define TUYA_OPENSDK_AUTHKEY   "keyxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"        // 请替换为正确的 AuthKey

/**
 * @brief AP 配网 PINCODE
 */
// #define TUYA_NETCFG_PINCODE   "69832860"

// clang-format on

#ifdef __cplusplus
}
#endif

#endif /* __TUYA_CONFIG_SECRETS_H__ */
